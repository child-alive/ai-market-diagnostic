# 复制为 .env 并填入你的 key（可选）。
# 缺失时系统自动切换到全 Mock 模式，依然可以完整跑通 demo。
DEEPSEEK_API_KEY=
# 可选覆盖项（以下为默认值）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_WEB_SEARCH=true
DEEPSEEK_SEARCH_MAX_USES=3

# 多平台检测（可选；缺失时不调用对应平台）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-search-api

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3.5-flash

# 在线演示防护（仅 src.demo_api 使用）
DEMO_RATE_LIMIT_PER_HOUR=2
DEMO_LIVE_TIMEOUT_SECONDS=180
DEMO_TRUST_PROXY=false
