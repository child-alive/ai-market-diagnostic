<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AI 海外市场诊断报告 — {{ r.brand_profile.brand_name }} × {{ r.brand_profile.market }}</title>
<script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
<style>
  :root {
    --navy: #102a43;
    --blue: #1769e0;
    --blue-2: #5b9cf6;
    --blue-pale: #edf5ff;
    --ink: #1c2b3a;
    --muted: #64788d;
    --line: #dce7f2;
    --paper: #ffffff;
    --canvas: #f4f8fc;
    --green: #147d64;
    --amber: #a66300;
    --red: #bd3a40;
    --shadow: 0 12px 34px rgba(31, 73, 125, .09);
  }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    color: var(--ink);
    background: var(--canvas);
    font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    line-height: 1.6;
  }
  a { color: inherit; }
  .page { width: min(1180px, calc(100% - 40px)); margin: 28px auto 64px; }
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 310px;
    padding: 44px 48px;
    color: #fff;
    border-radius: 24px;
    background: linear-gradient(128deg, #0c2847 0%, #1159af 62%, #2c82ed 100%);
    box-shadow: 0 24px 54px rgba(17, 75, 142, .22);
  }
  .hero::before, .hero::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,.16);
  }
  .hero::before { width: 360px; height: 360px; right: -90px; top: -180px; }
  .hero::after { width: 230px; height: 230px; right: 110px; bottom: -170px; }
  .eyebrow { margin: 0 0 18px; font-size: 12px; font-weight: 750; letter-spacing: .16em; text-transform: uppercase; opacity: .78; }
  h1 { max-width: 720px; margin: 0; font-size: clamp(34px, 5vw, 58px); line-height: 1.08; letter-spacing: -.035em; }
  h1 span { display: block; margin-top: 12px; font-size: .34em; font-weight: 500; letter-spacing: .04em; opacity: .76; }
  .hero-meta { display: flex; flex-wrap: wrap; gap: 12px 24px; margin-top: 34px; font-size: 14px; }
  .hero-meta div { display: grid; gap: 2px; }
  .hero-meta small { font-size: 10px; letter-spacing: .1em; text-transform: uppercase; opacity: .6; }
  .hero-meta strong { font-weight: 650; }
  .run-stamp { position: absolute; right: 48px; bottom: 42px; text-align: right; font-size: 12px; opacity: .74; }
  .data-notice {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    margin: 18px 0 28px;
    padding: 15px 18px;
    border: 1px solid #f1d292;
    border-radius: 13px;
    color: #72500a;
    background: #fff9e9;
    font-size: 13px;
  }
  .data-notice strong { color: #5c4008; }
  .data-notice.grounded { color: #165f50; border-color: #a8dccb; background: #ecfaf5; }
  .data-notice.grounded strong { color: #105344; }
  .summary {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 18px;
    margin-bottom: 34px;
  }
  .panel, .summary-card, .metric, .answer-card, .gap-card, .rec-card {
    border: 1px solid var(--line);
    background: var(--paper);
    box-shadow: var(--shadow);
  }
  .summary-card { padding: 24px 26px; border-radius: 18px; }
  .summary-card h2 { margin: 0 0 14px; font-size: 17px; color: var(--navy); }
  .summary-card p { margin: 0; color: #40556a; }
  .key-list { display: grid; gap: 10px; margin: 0; padding: 0; list-style: none; }
  .key-list li { display: flex; gap: 10px; color: #40556a; }
  .key-list b { flex: 0 0 28px; color: var(--blue); font-size: 12px; }
  section { margin-top: 44px; scroll-margin-top: 24px; }
  .section-head { display: flex; justify-content: space-between; gap: 16px; align-items: flex-end; margin-bottom: 17px; }
  .section-kicker { margin: 0 0 4px; color: var(--blue); font-size: 11px; font-weight: 750; letter-spacing: .14em; text-transform: uppercase; }
  h2 { margin: 0; color: var(--navy); font-size: 25px; letter-spacing: -.02em; }
  h2 small { margin-left: 8px; color: var(--muted); font-size: 12px; font-weight: 500; letter-spacing: .02em; }
  .section-note { max-width: 360px; margin: 0; color: var(--muted); font-size: 12px; text-align: right; }
  .metrics { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 13px; }
  .metric { position: relative; overflow: hidden; min-height: 142px; padding: 20px; border-radius: 17px; }
  .metric::after { content: ""; position: absolute; width: 56px; height: 56px; right: -16px; top: -18px; border-radius: 50%; background: var(--blue-pale); }
  .metric .label { min-height: 34px; color: var(--muted); font-size: 12px; font-weight: 650; }
  .metric .num { margin: 10px 0 2px; color: var(--navy); font-size: 31px; font-weight: 760; line-height: 1; letter-spacing: -.04em; }
  .metric .sub { color: #8797a8; font-size: 10px; }
  .metric.primary { border-color: #bcd7fb; background: linear-gradient(155deg, #fff 20%, #eef6ff); }
  .metric.primary .num { color: var(--blue); }
  .metric .mini-badge { position: absolute; right: 10px; bottom: 10px; }
  .grid-2 { display: grid; grid-template-columns: 1.2fr .8fr; gap: 18px; margin-top: 18px; }
  .panel { padding: 22px; border-radius: 18px; }
  .panel-title { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .panel-title h3 { margin: 0; color: var(--navy); font-size: 15px; }
  #sov-chart { height: 355px; }
  .chart-fallback { display: none; padding: 90px 24px; color: var(--muted); text-align: center; }
  .table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 15px; background: #fff; box-shadow: var(--shadow); }
  table { width: 100%; border-collapse: collapse; font-size: 12px; }
  th, td { padding: 12px 13px; border-bottom: 1px solid #e6edf5; text-align: left; vertical-align: top; }
  th { color: #60758a; background: #f5f9fd; font-size: 10px; font-weight: 750; letter-spacing: .05em; text-transform: uppercase; white-space: nowrap; }
  tr:last-child td { border-bottom: 0; }
  tbody tr:hover { background: #f8fbff; }
  .rank { color: #8ba0b3; font-variant-numeric: tabular-nums; }
  .strong { color: var(--navy); font-weight: 700; }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    border: 1px solid #cbdbea;
    border-radius: 999px;
    color: #557086;
    background: #f5f9fc;
    font-size: 9px;
    font-weight: 750;
    letter-spacing: .04em;
    white-space: nowrap;
  }
  .badge.mock { color: #855700; border-color: #e9c777; background: #fff6dc; }
  .badge.real, .badge.pass { color: #11684f; border-color: #a8dccb; background: #e9f8f2; }
  .badge.fail, .badge.P0 { color: #a72932; border-color: #edbcc0; background: #fff0f1; }
  .badge.P1 { color: #965900; border-color: #efd09a; background: #fff7e8; }
  .badge.P2 { color: #466176; border-color: #cbdbea; background: #f1f6fa; }
  .badge.supported { color: #11684f; border-color: #a8dccb; background: #e9f8f2; }
  .badge.partial { color: #965900; border-color: #efd09a; background: #fff7e8; }
  .badge.not_found, .badge.contradicted { color: #a72932; border-color: #edbcc0; background: #fff0f1; }
  .badge.inaccessible, .badge.unmapped { color: #526d84; border-color: #cbdbea; background: #f1f6fa; }
  .score { display: inline-grid; place-items: center; width: 24px; height: 24px; border-radius: 7px; color: #fff; background: var(--blue); font-weight: 750; }
  .question-text { min-width: 250px; color: var(--navy); font-weight: 620; }
  .question-zh { min-width: 175px; color: var(--muted); }
  .result-hit { color: var(--green); font-weight: 700; white-space: nowrap; }
  .result-miss { color: var(--red); font-weight: 650; white-space: nowrap; }
  .answers { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
  .answer-card { padding: 20px; border-radius: 16px; }
  .answer-head { display: flex; justify-content: space-between; gap: 10px; align-items: flex-start; }
  .answer-head h3 { margin: 0; color: var(--navy); font-size: 15px; }
  .answer-meta { display: flex; flex-wrap: wrap; gap: 7px; margin: 13px 0; }
  .evidence { margin: 8px 0; color: #5c7185; font-size: 12px; }
  .quote { padding: 10px 12px; border-left: 3px solid #b5d2f7; color: #405970; background: #f6faff; font-size: 12px; }
  details { margin-top: 12px; border-top: 1px solid var(--line); padding-top: 10px; }
  summary { color: var(--blue); cursor: pointer; font-size: 11px; font-weight: 650; }
  pre { max-height: 320px; overflow: auto; margin: 10px 0 0; white-space: pre-wrap; color: #475d71; font: 11px/1.65 ui-monospace, SFMono-Regular, Menlo, monospace; }
  .source-list { display: flex; flex-wrap: wrap; gap: 6px; margin: 8px 0 0; padding: 0; list-style: none; }
  .source-list a { display: inline-block; max-width: 230px; overflow: hidden; padding: 4px 8px; border: 1px solid #b9ddcf; border-radius: 8px; color: #126a54; background: #eefaf6; font-size: 10px; text-decoration: none; text-overflow: ellipsis; white-space: nowrap; }
  .source-list a:hover { border-color: #67b69b; background: #e2f6ef; }
  .platform-name { color: var(--navy); font-weight: 750; text-transform: uppercase; }
  .model-name { max-width: 210px; color: var(--muted); font: 10px/1.5 ui-monospace, SFMono-Regular, Menlo, monospace; overflow-wrap: anywhere; }
  .review-claim { min-width: 230px; color: var(--navy); font-weight: 620; }
  .review-quote { min-width: 250px; color: #506579; }
  .review-source { max-width: 230px; overflow-wrap: anywhere; }
  .review-source a { color: var(--blue); text-decoration: none; }
  .review-source a:hover { text-decoration: underline; }
  .audit-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 11px; }
  .audit-item { padding: 15px; border: 1px solid var(--line); border-radius: 13px; background: #fff; }
  .audit-item small { display: block; margin-bottom: 8px; color: var(--muted); font-size: 10px; }
  .audit-item strong { color: var(--navy); font-size: 13px; }
  .issue-list { display: grid; gap: 8px; margin-top: 14px; }
  .issue { display: grid; grid-template-columns: 75px 180px 1fr; gap: 14px; align-items: start; padding: 12px 14px; border: 1px solid var(--line); border-radius: 12px; background: #fff; font-size: 12px; }
  .issue code { color: #49647c; font-size: 10px; }
  .cards { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
  .gap-card, .rec-card { position: relative; padding: 21px; border-radius: 16px; }
  .gap-card::before, .rec-card::before { content: ""; position: absolute; left: 0; top: 18px; bottom: 18px; width: 3px; border-radius: 3px; background: var(--blue-2); }
  .card-top { display: flex; gap: 9px; align-items: center; margin-bottom: 10px; }
  .card-index { color: #93a5b6; font-size: 10px; font-weight: 750; }
  .gap-card h3, .rec-card h3 { margin: 0; color: var(--navy); font-size: 15px; }
  .evidence-list { margin: 11px 0 0; padding: 0; list-style: none; }
  .evidence-list li { position: relative; margin: 6px 0; padding-left: 14px; color: #5e7285; font-size: 12px; }
  .evidence-list li::before { content: ""; position: absolute; left: 0; top: .65em; width: 5px; height: 5px; border-radius: 50%; background: #82afe9; }
  .rec-card.P0::before { background: var(--red); }
  .rec-card.P1::before { background: #e49a2f; }
  .rec-card.P2::before { background: #7990a5; }
  .rec-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 11px; margin-top: 13px; }
  .rec-grid div { padding: 10px; border-radius: 10px; background: #f6f9fc; }
  .rec-grid small { display: block; margin-bottom: 3px; color: #8999a8; font-size: 9px; }
  .rec-grid span { color: #506579; font-size: 11px; }
  footer { margin-top: 44px; padding: 23px 4px; border-top: 1px solid #cfdeec; color: #788da0; font-size: 11px; }
  footer strong { color: #526d84; }
  @media (max-width: 900px) {
    .metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid-2, .summary { grid-template-columns: 1fr; }
    .answers, .cards { grid-template-columns: 1fr; }
    .audit-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .run-stamp { position: static; margin-top: 24px; text-align: left; }
  }
  @media (max-width: 600px) {
    .page { width: min(100% - 20px, 1180px); margin-top: 10px; }
    .hero { padding: 30px 24px; border-radius: 17px; }
    .metrics, .audit-grid { grid-template-columns: 1fr; }
    .section-head { display: block; }
    .section-note { margin-top: 7px; text-align: left; }
    .issue { grid-template-columns: 1fr; gap: 5px; }
    .rec-grid { grid-template-columns: 1fr; }
  }
  @media print {
    body { background: #fff; }
    .page { width: 100%; margin: 0; }
    .hero, .panel, .summary-card, .metric, .answer-card, .gap-card, .rec-card, .table-wrap { box-shadow: none; }
    section, .answer-card, .gap-card, .rec-card { break-inside: avoid; }
    details { display: none; }
  }
</style>
</head>
<body>
{% set m = r.metrics %}
{% set um = m.unbranded %}
{% set bm = m.branded %}
{% set s = r.site_audit %}
{% set checked_ids = r.answers|map(attribute="question_id")|list %}
{% set analysis_map = {} %}
{% for a in r.analyses %}{% if analysis_map.update({a.question_id: a}) %}{% endif %}{% endfor %}
{% set question_map = {} %}
{% for q in r.questions %}{% if question_map.update({q.id: q}) %}{% endif %}{% endfor %}
{% set mock_count = r.answers|selectattr("is_mock")|list|length %}
{% set grounded_count = r.answers|selectattr("search_grounded")|list|length %}
{% set primary_provider = r.platform_results[0].provider if r.platform_results else (r.answers[0].provider if r.answers else "unknown") %}
{% set evidence_ns = namespace(total=0) %}
{% for p in r.platform_results %}{% set evidence_ns.total = evidence_ns.total + (p.evidence_reviews|length) %}{% endfor %}

<main class="page">
  <header class="hero">
    <p class="eyebrow">GEO MARKET INTELLIGENCE · 市场诊断原型</p>
    <h1>AI 海外市场诊断报告<span>Diagnóstico de visibilidad de marca en IA</span></h1>
    <div class="hero-meta">
      <div><small>Marca / 品牌</small><strong>{{ r.brand_profile.brand_name }} · {{ r.brand_profile.brand_aliases[0] if r.brand_profile.brand_aliases else "" }}</strong></div>
      <div><small>Mercado / 市场</small><strong>{{ r.brand_profile.market }}</strong></div>
      <div><small>Idioma / 语言</small><strong>{{ r.brand_profile.language }}</strong></div>
      <div><small>Categoría / 品类</small><strong>{{ r.brand_profile.category }}</strong></div>
    </div>
    <div class="run-stamp">{{ r.meta.generated_at.strftime("%Y-%m-%d · %H:%M UTC") }}<br>RUN {{ r.meta.run_id }}{% if r.meta.providers %}<br>{{ r.meta.providers|join(" · ")|upper }}{% elif r.meta.model %}<br>{{ r.meta.model }}{% endif %}{% if r.meta.web_search_enabled %} · WEB SEARCH{% endif %}</div>
  </header>

  {% if r.meta.mode.value == "mock" or mock_count %}
  <div class="data-notice">
    <span class="badge mock">MOCK DATA</span>
    <div><strong>本报告包含模拟回放数据。</strong> 当前 {{ mock_count }}/{{ r.answers|length }} 条 AI 回答来自 fixtures；由其派生的可见度、SOV、排名、引用与情感指标均用于验证诊断链路，不代表真实平台市场表现。</div>
  </div>
  {% endif %}

  {% if grounded_count %}
  <div class="data-notice grounded">
    <span class="badge real">WEB SEARCH</span>
    <div><strong>主平台 {{ primary_provider|upper }} 的 {{ grounded_count }}/{{ r.answers|length }} 条回答启用了联网搜索。</strong> 来源 URL 直接来自对应平台 API，可在回答卡片中查看；{% if evidence_ns.total %}本次另做了页面级机器证据预审，但全部结果仍需人工复核。{% else %}本次未运行页面级证据预审，不能据此认定每个来源都支持对应结论。{% endif %}</div>
  </div>
  {% endif %}

  <div class="summary">
    <article class="summary-card">
      <h2>执行摘要 <small>Resumen ejecutivo</small></h2>
      {% if um.visibility_rate == 0 %}
      <p><strong>RUN {{ r.meta.run_id }}</strong> 的 {{ um.questions_checked }} 个高价值无品牌词问题中，得力未被 AI 主动提及：<strong>无品牌词可见度 0%</strong>。与此同时，{{ bm.questions_checked }} 个含品牌词问题中有 {{ (bm.visibility_rate * bm.questions_checked)|round|int }} 个获得品牌描述，说明“AI 认得得力”不等于“AI 会主动推荐得力”。{% if not s.spanish_content_found or not s.has_es_mx_hreflang %}在本次官网抓取的 {{ s.pages_checked }} 页范围内，{% if not s.spanish_content_found %}未发现西语内容{% endif %}{% if not s.spanish_content_found and not s.has_es_mx_hreflang %}，且{% endif %}{% if not s.has_es_mx_hreflang %}未发现 es-MX hreflang{% endif %}，品牌需要补齐本地化的内容承接面。{% endif %}</p>
      {% else %}
      <p><strong>RUN {{ r.meta.run_id }}</strong> 的 {{ um.questions_checked }} 个高价值无品牌词问题中，得力被主动提及 {{ (um.visibility_rate * um.questions_checked)|round|int }} 次，<strong>无品牌词可见度 {{ "%.0f%%"|format(um.visibility_rate*100) }}</strong>、SOV {{ "%.1f%%"|format(um.sov*100) }}。该数字与品牌词认知指标已分开，只表示本次单轮样本。</p>
      {% endif %}
    </article>
    <article class="summary-card">
      <h2>优先判断 <small>Lecturas clave</small></h2>
      <ul class="key-list">
        <li><b>01</b><span>先补齐墨西哥西语市场入口与 <strong>es-MX hreflang</strong>，建立可理解、可承接的地域信号。</span></li>
        <li><b>02</b><span>围绕高价值品类问法建设可引用内容，提升进入 AI 推荐列表的概率。</span></li>
        <li><b>03</b><span>用多轮、多平台、100+ 问题采样校准本报告的方向性结论。</span></li>
      </ul>
    </article>
  </div>

  <section id="metrics">
    <div class="section-head">
      <div><p class="section-kicker">01 · Performance</p><h2>AI 可见度指标 <small>Métricas de visibilidad</small></h2></div>
      <p class="section-note">头部竞争力指标只统计无品牌词；品牌词另作认知与情感诊断。平均排名越低越好。</p>
    </div>
    <div class="metrics">
      <article class="metric primary"><div class="label">Unbranded Visibility<br>无品牌词可见度</div><div class="num">{{ "%.0f%%"|format(um.visibility_rate*100) }}</div><div class="sub">主动提及 / 无品牌词回答</div>{% if mock_count %}<span class="badge mock mini-badge">MOCK DERIVED</span>{% endif %}</article>
      <article class="metric"><div class="label">Unbranded SOV<br>无品牌词话语权</div><div class="num">{{ "%.1f%%"|format(um.sov*100) }}</div><div class="sub">无品牌词中的品牌提及占比</div>{% if mock_count %}<span class="badge mock mini-badge">MOCK DERIVED</span>{% endif %}</article>
      <article class="metric"><div class="label">Unbranded Avg Position<br>无品牌词平均排名</div><div class="num">{{ um.avg_position if um.avg_position is not none else "—" }}</div><div class="sub">主动被提及时的顺位</div>{% if mock_count %}<span class="badge mock mini-badge">MOCK DERIVED</span>{% endif %}</article>
      <article class="metric"><div class="label">Unbranded Citation<br>{{ "联网引用率" if grounded_count else "声明引用率" }}</div><div class="num">{{ "%.0f%%"|format(um.citation_rate*100) }}</div><div class="sub">{% if grounded_count %}无品牌词且含搜索来源 URL{% else %}回答声明域名的占比 · 未核验{% endif %}</div>{% if mock_count %}<span class="badge mock mini-badge">MOCK DERIVED</span>{% endif %}</article>
      <article class="metric"><div class="label">Branded Sentiment<br>品牌词情感</div><div class="num">{{ bm.sentiment_summary.get("pos",0) }}·{{ bm.sentiment_summary.get("neu",0) }}·{{ bm.sentiment_summary.get("neg",0) }}</div><div class="sub">正面 · 中性 · 负面</div>{% if mock_count %}<span class="badge mock mini-badge">MOCK DERIVED</span>{% endif %}</article>
    </div>

    <div class="grid-2">
      <div class="panel">
        <div class="panel-title"><h3>无品牌词话语权对比 · Unbranded SOV</h3>{% if mock_count %}<span class="badge mock">MOCK DERIVED</span>{% endif %}</div>
        <div id="sov-chart" role="img" aria-label="得力与竞品话语权对比柱状图"></div>
        <div id="chart-fallback" class="chart-fallback">图表组件未加载，请参考右侧竞品排行表。</div>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>#</th><th>Marca / 品牌</th><th>Menciones / 提及</th><th>Posición / 排名</th><th>SOV</th></tr></thead>
          <tbody>
            <tr><td class="rank">—</td><td class="strong">{{ r.brand_profile.brand_name }}（目标品牌）</td><td>{{ (um.visibility_rate * um.questions_checked)|round|int }}</td><td>{{ um.avg_position if um.avg_position is not none else "—" }}</td><td class="strong">{{ "%.1f%%"|format(um.sov*100) }}</td></tr>
            {% for c in um.competitor_ranking[:9] %}
            <tr><td class="rank">{{ "%02d"|format(loop.index) }}</td><td>{{ c.name }}</td><td>{{ c.mention_count }}</td><td>{{ c.avg_position if c.avg_position is not none else "—" }}</td><td>{{ "%.1f%%"|format(c.sov*100) }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {% if bm.questions_checked %}
  <section id="brand-cognition">
    <div class="section-head">
      <div><p class="section-kicker">Brand cognition</p><h2>品牌认知与情感诊断 <small>Consultas de marca · {{ bm.questions_checked }}</small></h2></div>
      <p class="section-note">品牌词回答不计入主动推荐竞争力；此处检查 AI 是否认得品牌、如何描述以及情感倾向。</p>
    </div>
    <div class="data-notice">
      <span class="badge partial">HUMAN REVIEW</span>
      <div><strong>描述准确性和时效性仍需逐条人工复核。</strong> 下表的“证据句”只是模型回答中支撑情感/提及判断的原文，不代表其中的事实已被核验。</div>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>问题</th><th>品牌提及</th><th>情感</th><th>AI 描述证据句</th><th>准确性</th></tr></thead>
        <tbody>
          {% for q in r.questions if q.query_scope and q.query_scope.value == "branded" and q.id in checked_ids %}
          {% set an = analysis_map[q.id] %}
          <tr>
            <td><span class="rank">{{ q.id }}</span><br><span class="question-text">{{ q.text_local }}</span></td>
            <td>{% if an.brand_mentioned %}<span class="result-hit">✓ 第 {{ an.brand_position }} 位</span>{% else %}<span class="result-miss">× 未提及</span>{% endif %}</td>
            <td><span class="badge">{{ {"pos":"正面","neu":"中性","neg":"负面"}[an.sentiment.value] }}</span></td>
            <td class="review-quote">{{ an.evidence_quote or "未抽取到证据句" }}</td>
            <td><span class="badge partial">待人工复核</span></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  {% if r.platform_results|length > 1 %}
  <section id="platform-comparison">
    <div class="section-head">
      <div><p class="section-kicker">02 · Platforms</p><h2>多平台横向对比 <small>Comparativa · {{ r.platform_results|length }}</small></h2></div>
      <p class="section-note">各平台独立提问、独立统计，不混合成一个平均值；内容缺口与行动建议仍以主平台 {{ primary_provider|upper }} 为准。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>平台</th><th>模型</th><th>回答</th><th>联网回答</th><th>无品牌词可见度</th><th>Unbranded SOV</th><th>无品牌词平均排名</th><th>无品牌词引用率</th><th>证据预审</th></tr></thead>
        <tbody>
          {% for p in r.platform_results %}
          {% set p_grounded = p.answers|selectattr("search_grounded")|list|length %}
          <tr>
            <td><span class="platform-name">{{ p.provider }}</span>{% if loop.first %}<br><span class="badge">主平台</span>{% endif %}</td>
            <td class="model-name">{{ p.model or "—" }}</td>
            <td>{{ p.answers|length }}</td><td>{{ p_grounded }}/{{ p.answers|length }}</td>
            <td class="strong">{{ "%.0f%%"|format(p.metrics.unbranded.visibility_rate*100) }}</td><td>{{ "%.1f%%"|format(p.metrics.unbranded.sov*100) }}</td>
            <td>{{ p.metrics.unbranded.avg_position if p.metrics.unbranded.avg_position is not none else "—" }}</td><td>{{ "%.0f%%"|format(p.metrics.unbranded.citation_rate*100) }}</td>
            <td>{% if p.evidence_reviews %}{{ p.evidence_metrics.supported }}/{{ p.evidence_metrics.total_claims }} 支持<br><span class="badge partial">机器预审</span>{% else %}<span class="badge unmapped">未运行</span>{% endif %}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  <section id="questions">
    <div class="section-head">
      <div><p class="section-kicker">{{ "03" if r.platform_results|length > 1 else "02" }} · Demand</p><h2>用户问题地图 <small>Mapa de preguntas · {{ r.questions|length }}</small></h2></div>
      <p class="section-note">问题按品牌词 / 地区排名词 / 品类词与 TOFU / MOFU / BOFU 双维度分类。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>ID</th><th>Pregunta / 西语问题</th><th>中文对照</th><th>Tipo / 分类</th><th>Funnel</th><th>Valor / 价值</th><th>Resultado / 检测结果</th></tr></thead>
        <tbody>
          {% for q in r.questions %}
          <tr>
            <td class="rank">{{ q.id }}</td><td class="question-text">{{ q.text_local }}</td><td class="question-zh">{{ q.text_zh }}</td>
            <td><span class="badge">{{ {"brand":"品牌词","regional":"地区排名词","category":"品类排名词"}[q.tier.value] }}</span><br>{% if q.query_scope %}<span class="badge {{ 'P1' if q.query_scope.value == 'branded' else 'pass' }}">{{ "BRANDED / 品牌词" if q.query_scope.value == "branded" else "UNBRANDED / 无品牌词" }}</span>{% endif %}</td>
            <td><span class="badge">{{ q.funnel.value }}</span></td><td><span class="score">{{ q.value_score }}</span></td>
            <td>
              {% if q.id in checked_ids %}
                {% set an = analysis_map[q.id] %}
                {% if an.brand_mentioned %}<span class="result-hit">✓ 提及 · 第 {{ an.brand_position }} 位</span>{% else %}<span class="result-miss">× 未提及</span>{% endif %}
                {% set answer = (r.answers|selectattr("question_id", "equalto", q.id)|list|first) %}
                {% if answer.is_mock %}<span class="badge mock">MOCK</span>{% endif %}
              {% else %}<span class="badge">未检测</span>{% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section id="answers">
    <div class="section-head">
      <div><p class="section-kicker">{{ "04" if r.platform_results|length > 1 else "03" }} · Evidence</p><h2>主平台回答与引用 <small>{{ primary_provider|upper }} · Respuestas</small></h2></div>
      <p class="section-note">此处展示主平台回答；“API 返回来源”与“来源支持结论”是两个不同层级。</p>
    </div>
    <div class="answers">
      {% for a in r.answers %}
      {% set an = analysis_map[a.question_id] %}
      {% set q = question_map[a.question_id] %}
      <article class="answer-card">
        <div class="answer-head"><h3>{{ a.question_id }} · {% if an.brand_mentioned %}品牌已进入答案{% else %}品牌未进入答案{% endif %}</h3><div>{% if a.is_mock %}<span class="badge mock">MOCK</span>{% else %}<span class="badge real">{{ a.provider|upper }}</span>{% endif %} {% if a.search_grounded %}<span class="badge real">WEB SEARCH · {{ a.source_urls|length }}</span>{% endif %} {% if an.parse_degraded %}<span class="badge mock">解析降级</span>{% endif %}</div></div>
        <div class="answer-meta">
          {% if a.model %}<span class="badge">{{ a.model }}</span>{% endif %}
          {% if q.query_scope %}<span class="badge {{ 'P1' if q.query_scope.value == 'branded' else 'pass' }}">{{ q.query_scope.value|upper }}</span>{% endif %}
          <span class="badge {{ 'pass' if an.brand_mentioned else 'fail' }}">提及 {{ "是 · 第 %d 位"|format(an.brand_position) if an.brand_mentioned else "否" }}</span>
          <span class="badge">情感 {{ {"pos":"正面","neu":"中性","neg":"负面"}[an.sentiment.value] }}</span>
          <span class="badge">引用 {{ an.citations|length }}</span>
        </div>
        <p class="evidence"><strong>竞品：</strong>{{ an.competitors|map(attribute="name")|join("、") or "无" }}</p>
        {% if a.search_grounded and an.citations %}
        <p class="evidence"><strong>联网检索来源：</strong>以下 URL 来自 {{ a.provider|upper }} API 返回结果；此标签本身不等于内容已核验</p>
        <ul class="source-list">{% for c in an.citations %}<li><a href="{{ c.url }}" target="_blank" rel="noopener noreferrer" title="{{ c.url }}">{{ c.domain }}</a></li>{% endfor %}</ul>
        {% else %}
        <p class="evidence"><strong>声明引用源（未核验）：</strong>{{ an.citations|map(attribute="domain")|join("、") or "无" }}</p>
        {% endif %}
        {% if an.evidence_quote %}<div class="quote">“{{ an.evidence_quote }}”</div>{% endif %}
        <details><summary>查看 AI 回答原文 · Ver respuesta original</summary><pre>{{ a.raw_text }}</pre></details>
      </article>
      {% endfor %}
    </div>
  </section>

  {% if evidence_ns.total %}
  <section id="evidence-review">
    <div class="section-head">
      <div><p class="section-kicker">Verification · Machine pre-audit</p><h2>来源证据预审 <small>{{ evidence_ns.total }} 条陈述</small></h2></div>
      <p class="section-note"><span class="badge partial">机器预审 · 需人工复核</span> 仅比较回答陈述与来源页面的词面覆盖，不等同于事实核查，也不输出“已人工审核”。</p>
    </div>
    <div class="data-notice">
      <span class="badge partial">LIMITATION</span>
      <div><strong>如何阅读：</strong>“支持”表示页面找到了高度重合的证据片段；“部分支持/未找到”表示需要重点人工检查；“无法访问/未映射”表示当前链路无法形成判断。机器预审不能识别所有语义改写、时间变化或上下文矛盾。</div>
    </div>
    {% for p in r.platform_results if p.evidence_reviews %}
    <div class="panel-title"><h3>{{ p.provider|upper }} · {{ p.model }} · 支持 {{ p.evidence_metrics.supported }}/{{ p.evidence_metrics.total_claims }}</h3><span class="badge partial">支持率 {{ "%.0f%%"|format(p.evidence_metrics.support_rate*100) }}</span></div>
    <div class="table-wrap" style="margin-bottom:18px">
      <table>
        <thead><tr><th>状态</th><th>问题</th><th>待核陈述</th><th>页面证据片段</th><th>来源</th><th>词面分</th></tr></thead>
        <tbody>
          {% for review in p.evidence_reviews %}
          <tr>
            <td><span class="badge {{ review.status.value }}">{{ {"supported":"支持","partial":"部分支持","not_found":"未找到","inaccessible":"无法访问","unmapped":"未映射","contradicted":"疑似矛盾"}[review.status.value] }}</span></td>
            <td class="rank">{{ review.question_id }}</td><td class="review-claim">{{ review.claim or "—" }}</td>
            <td class="review-quote">{{ review.evidence_quote or review.error or "—" }}</td>
            <td class="review-source">{% if review.source_url %}<a href="{{ review.source_url }}" target="_blank" rel="noopener noreferrer">{{ review.source_title or review.source_url }}</a>{% else %}—{% endif %}</td>
            <td>{{ "%.0f%%"|format(review.support_score*100) }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endfor %}
  </section>
  {% endif %}

  <section id="site-audit">
    <div class="section-head">
      <div><p class="section-kicker">Foundation</p><h2>网站可引用性诊断 <small>Auditoría del sitio</small></h2></div>
      <p class="section-note">{% if s.snapshot_mode %}<span class="badge mock">SNAPSHOT · 快照模式</span>{% else %}<span class="badge real">LIVE AUDIT · 实时抓取</span>{% endif %} 共检查 {{ s.pages_checked }} 页</p>
    </div>
    <div class="audit-grid">
      {% set checks = [
        ("可抓取 / Rastreable", s.crawlable),
        ("robots.txt 允许", s.robots_ok),
        ("Sitemap 存在", s.sitemap_found),
        ("es-MX hreflang", s.has_es_mx_hreflang),
        ("JSON-LD 结构化数据", s.has_structured_data),
        ("西语内容 / Español", s.spanish_content_found)
      ] %}
      {% for label, passed in checks %}
      <div class="audit-item"><small>{{ label }}</small><strong>{{ "通过" if passed else "需修复" }}</strong> <span class="badge {{ 'pass' if passed else 'fail' }}">{{ "PASS" if passed else "GAP" }}</span></div>
      {% endfor %}
      <div class="audit-item"><small>检查页面 / Páginas</small><strong>{{ s.pages_checked }} 页</strong></div>
      <div class="audit-item"><small>数据模式 / Modo</small><strong>{{ "快照回放" if s.snapshot_mode else "实时抓取" }}</strong></div>
    </div>
    {% if s.advanced_checks_completed %}
    <div class="grid-2">
      <div class="table-wrap">
        <table>
          <thead><tr><th>AI 爬虫</th><th>用途</th><th>robots.txt</th><th>规则来源</th></tr></thead>
          <tbody>
            {% for purpose, label in [("retrieval", "搜索 / 引用爬虫"), ("both", "训练 + Grounding 控制 token"), ("training", "训练 / 数据采集爬虫")] %}
            <tr><td colspan="4" class="strong">{{ label }}</td></tr>
            {% for crawler in s.ai_crawlers if crawler.purpose.value == purpose %}
            <tr>
              <td class="model-name">{{ crawler.user_agent }}</td>
              <td>{{ "检索/引用" if purpose == "retrieval" else "训练 + Grounding" if purpose == "both" else "训练/数据采集" }}</td>
              <td><span class="badge {{ 'pass' if crawler.allowed else 'fail' }}">{{ "ALLOW" if crawler.allowed else "BLOCK" }}</span></td>
              <td>{{ {"specific":"专用规则","wildcard":"继承 User-agent: *","no_rule":"未声明（默认允许）"}[crawler.rule_source] }}</td>
            </tr>
            {% endfor %}
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="panel">
        <div class="panel-title"><h3>AI 可读性与内容可提取性</h3><span class="badge">HEURISTIC</span></div>
        <div class="audit-grid" style="grid-template-columns:repeat(2,minmax(0,1fr))">
          {% set advanced_checks = [
            ("llms.txt", s.llms_txt_found, "根目录文件"),
            ("llms-full.txt", s.llms_full_txt_found, "完整内容导航"),
            ("原始 HTML 品牌实体", s.brand_in_raw_html, s.raw_html_text_chars|string + " 字符"),
            ("不依赖客户端 JS", not s.likely_js_dependent, "原始 HTML 启发式"),
            ("直接回答式段落", s.direct_answer_content_found, "段落长度启发式"),
            ("FAQ 结构", s.faq_content_found, "FAQPage / details / 标题")
          ] %}
          {% for label, passed, detail in advanced_checks %}
          <div class="audit-item"><small>{{ label }}</small><strong>{{ "已发现" if passed else "未发现 / 需复核" }}</strong><br><span class="badge {{ 'pass' if passed else 'P2' }}">{{ "PASS" if passed else "GAP" }}</span> <small style="display:inline">{{ detail }}</small></div>
          {% endfor %}
        </div>
        <p class="evidence"><strong>口径：</strong><code>llms.txt</code> 是新兴约定，缺失不等于无法被 AI 抓取；屏蔽训练爬虫也是可合理的数据权利选择。搜索/引用或 Grounding 相关访问被屏蔽，才可能直接影响 GEO 可见性。Google-Extended 是控制 token，并非独立 HTTP user-agent。</p>
      </div>
    </div>
    {% else %}
    <div class="data-notice">
      <span class="badge">LEGACY RUN</span>
      <div><strong>该历史运行生成时尚未记录 AI 爬虫、llms.txt 与 JS 可见性字段。</strong> 页面不用默认 false 冒充实测结论；新运行会自动完成这些检查。</div>
    </div>
    {% endif %}
    {% if s.issues %}
    <div class="issue-list">
      {% for i in s.issues %}<div class="issue"><span class="badge {{ 'P0' if i.severity.value == 'high' else 'P1' if i.severity.value == 'medium' else 'P2' }}">{{ i.severity.value|upper }}</span><code>{{ i.code }}</code><span>{{ i.detail }}</span></div>{% endfor %}
    </div>
    {% endif %}
  </section>

  <section id="gaps">
    <div class="section-head">
      <div><p class="section-kicker">Opportunity</p><h2>内容与信号缺口 <small>Brechas · {{ r.gaps|length }}</small></h2></div>
      <p class="section-note">每个缺口均由问题、回答指标或网站检查结果提供证据，不做无依据推断。</p>
    </div>
    <div class="cards">
      {% for g in r.gaps %}
      <article class="gap-card">
        <div class="card-top"><span class="card-index">{{ "%02d"|format(loop.index) }}</span><span class="badge">{{ {"page":"页面 PAGE","topic":"主题 TOPIC","signal":"信号 SIGNAL"}[g.gap_type.value] }}</span></div>
        <h3>{{ g.title }}</h3>
        <ul class="evidence-list">{% for e in g.evidence %}<li>{{ e }}</li>{% endfor %}</ul>
        {% if g.related_questions %}<p class="evidence"><strong>关联问题：</strong>{{ g.related_questions|join(" · ") }}</p>{% endif %}
      </article>
      {% endfor %}
    </div>
  </section>

  <section id="recommendations">
    <div class="section-head">
      <div><p class="section-kicker">Action</p><h2>优先行动路线图 <small>Plan de acción · {{ r.recommendations|length }}</small></h2></div>
      <p class="section-note">P0 立即处理，P1 进入近期内容排期，P2 作为规模化能力建设。</p>
    </div>
    <div class="cards">
      {% for rec in r.recommendations %}
      <article class="rec-card {{ rec.priority.value }}">
        <div class="card-top"><span class="card-index">{{ "%02d"|format(loop.index) }}</span><span class="badge {{ rec.priority.value }}">{{ rec.priority.value }}</span><span class="badge">EFFORT {{ rec.effort.value }}</span></div>
        <h3>{{ rec.action }}</h3>
        <div class="rec-grid">
          <div><small>WHY / 理由</small><span>{{ rec.reason }}</span></div>
          <div><small>IMPACT / 预期影响</small><span>{{ rec.expected_impact }}</span></div>
          <div><small>EFFORT / 工作量</small><span>{{ rec.effort.value }} · {{ {"S":"小","M":"中","L":"大"}[rec.effort.value] }}</span></div>
        </div>
      </article>
      {% endfor %}
    </div>
  </section>

  <footer>
    <strong>AI 海外市场诊断智能体 · Prototype</strong><br>
    运行 ID {{ r.meta.run_id }} · 模式 {{ r.meta.mode.value }}{% if r.meta.providers %} · 平台 {{ r.meta.providers|join(", ") }}{% elif r.meta.model %} · 模型 {{ r.meta.model }}{% endif %} · 生成于 {{ r.meta.generated_at.isoformat() }}。标注 MOCK 的回答及其派生指标为模拟回放；快照模式的网站结果来自已保存的公开页面快照；WEB SEARCH URL 来自对应平台 API。{% if evidence_ns.total %}来源支持关系仅完成机器预审，全部结果仍需人工复核。{% else %}来源支持关系未做页面级核验。{% endif %}
  </footer>
</main>

<script id="report-data" type="application/json">{{ r.model_dump(mode="json")|tojson }}</script>
<script>
  (function () {
    const chartNode = document.getElementById("sov-chart");
    const fallback = document.getElementById("chart-fallback");
    if (!window.echarts) {
      chartNode.style.display = "none";
      fallback.style.display = "block";
      return;
    }
    const names = [{{ r.brand_profile.brand_name|tojson }}{% for c in um.competitor_ranking[:7] %}, {{ c.name|tojson }}{% endfor %}];
    const values = [{{ (um.sov * 100)|round(1) }}{% for c in um.competitor_ranking[:7] %}, {{ (c.sov * 100)|round(1) }}{% endfor %}];
    const chart = echarts.init(chartNode, null, {renderer: "svg"});
    chart.setOption({
      animationDuration: 700,
      grid: {left: 92, right: 36, top: 26, bottom: 34},
      tooltip: {trigger: "axis", axisPointer: {type: "shadow"}, valueFormatter: value => value + "%"},
      xAxis: {type: "value", axisLabel: {formatter: "{value}%", color: "#72879a"}, splitLine: {lineStyle: {color: "#e8f0f7"}}},
      yAxis: {type: "category", inverse: true, data: names, axisTick: {show: false}, axisLine: {show: false}, axisLabel: {color: "#40566b", fontWeight: 600}},
      series: [{type: "bar", data: values.map((value, index) => ({value, itemStyle: {color: index === 0 ? "#1769e0" : "#8db8ee", borderRadius: [0, 5, 5, 0]}})), barWidth: 18, label: {show: true, position: "right", formatter: "{c}%", color: "#536a7e", fontSize: 10}}]
    });
    window.addEventListener("resize", () => chart.resize());
  })();
</script>
</body>
</html>
